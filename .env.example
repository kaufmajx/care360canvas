# ----------------------------------------------------------------------
# Copy this file to ".env.local" and fill in your key, then restart `npm run dev`.
#
#   cp .env.example .env.local
#
# Google Gemini API key (free tier). Get one at https://aistudio.google.com/apikey
# This key is used only server-side (in app/api/generate/route.ts) and is
# never exposed to the browser.
# ----------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# CLAUDE API MIGRATION: when moving to the Anthropic API, replace the line
# above with ANTHROPIC_API_KEY=... and update app/api/generate/route.ts.
